# ================================================
# Environment Variables Template
# ================================================
# SETUP:
#   1. Copy this file:  copy .env.example .env
#   2. Edit .env with YOUR values
#   3. NEVER commit .env to Git (it's in .gitignore)
# ================================================

# --- Flask ---
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True

# --- Database ---
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/inventory_db

# --- Test Database (used by pytest) ---
TEST_DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/inventory_db_test
